# Build / Gradle
*.iml
.gradle/
**/.gradle/
/build
**/build/
.kotlin/
**/.kotlin/
/captures
.externalNativeBuild
.cxx
*.hprof

# Local config (절대 커밋 금지 — 디바이스/사용자별)
local.properties
**/local.properties

# iOS auth secrets (Google OAuth client id + BFF base URL). template 만 커밋.
# Auth.xcconfig = Debug (로컬 IP), Auth.release.xcconfig = Release (production HTTPS).
iosApp/Configs/Auth.xcconfig
iosApp/Configs/Auth.release.xcconfig

# IDE
/.idea
.idea/
*.iml

# macOS
.DS_Store

# Xcode
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
# Xcode build output (xcodebuild -derivedDataPath build-device|build-simulator)
iosApp/build-device/
iosApp/build-simulator/
# Xcode SwiftPM workspace cache (locally generated)
# Package.resolved 는 Xcode Cloud 가 요구 — lockfile 로 커밋, 나머지 캐시만 ignore.
# 디렉토리 자체를 ignore 하면 `!` 로 자식을 되살릴 수 없어 `/*` 로 contents 만 ignore.
**/xcshareddata/swiftpm/*
!**/xcshareddata/swiftpm/Package.resolved
