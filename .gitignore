# Build / Gradle
*.iml
.gradle/
**/.gradle/
/build
**/build/
.kotlin/
**/.kotlin/
/captures
.externalNativeBuild
.cxx
*.hprof
# JVM fatal error logs (Kotlin/Native LLVM 백엔드 등 native crash 시 cwd 에 떨어짐)
hs_err_pid*.log
replay_pid*.log

# Local config (절대 커밋 금지 — 디바이스/사용자별)
local.properties
**/local.properties

# Auth.xcconfig (Debug) 만 ignore — BFF_BASE_URL 이 개발자별 LAN IP 라 커밋 시 충돌.
# Auth.release.xcconfig (Release) 의 값들은 모두 빌드 산출물에 박혀 배포되는 public
# 정보 (Google iOS OAuth client id = public client, api.vibi.fm = 트래픽으로 노출,
# DEVELOPMENT_TEAM = App Store 페이지 노출) — Xcode Cloud 공급 위해 커밋.
iosApp/Configs/Auth.xcconfig

# IDE
/.idea
.idea/
*.iml

# macOS
.DS_Store

# Xcode
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
# Xcode build output (xcodebuild -derivedDataPath build-device|build-simulator)
iosApp/build-device/
iosApp/build-simulator/
# Xcode SwiftPM workspace cache (locally generated)
# Package.resolved 는 Xcode Cloud 가 요구 — lockfile 로 커밋, 나머지 캐시만 ignore.
# 디렉토리 자체를 ignore 하면 `!` 로 자식을 되살릴 수 없어 `/*` 로 contents 만 ignore.
**/xcshareddata/swiftpm/*
!**/xcshareddata/swiftpm/Package.resolved
