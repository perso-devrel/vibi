<?xml version="1.0" encoding="utf-8"?>
<!--
  TextureView-backed PlayerView used inside the Frame setup sheet. SurfaceView
  (the default) renders on a hardware overlay that ignores Compose clipping, so
  panned/zoomed video escapes the sheet. TextureView composes into the normal
  view hierarchy and respects clipToBounds.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false" />
